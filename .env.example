DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME?schema=public"
NOVAPAY_PUBLIC_BASE_URL="http://localhost:3000"
NOVAPAY_DATA_ENCRYPTION_KEY="CHANGE_TO_A_32_BYTE_SECRET_KEY"
ADMIN_BOOTSTRAP_EMAIL="admin@example.com"
ADMIN_BOOTSTRAP_PASSWORD="CHANGE_ME"
ADMIN_BOOTSTRAP_NAME="Platform Administrator"
PAYMENT_EXPIRE_MINUTES="30"
CALLBACK_TIMEOUT_MS="10000"
CALLBACK_MAX_ATTEMPTS="6"
CALLBACK_RETRY_INTERVAL_SECONDS="60"
CALLBACK_WORKER_BATCH_SIZE="20"
CALLBACK_WORKER_INTERVAL_MS="5000"
FINANCE_WORKER_INTERVAL_MS="60000"
SETTLEMENT_HOLD_DAYS="1"
MERCHANT_SIGNATURE_MAX_AGE_SECONDS="300"

# Merchant-owned channel credentials and upstream callback URLs are configured
# per channel instance in the merchant console, not in platform env vars.
