{
  "name": "novapay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --test --import tsx tests/*.test.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "db:migrate-secrets": "tsx scripts/migrate-secret-storage.ts",
    "callbacks:retry-once": "tsx scripts/callback-retry-worker.ts --once",
    "callbacks:worker": "tsx scripts/callback-retry-worker.ts",
    "finance:sync-once": "tsx scripts/finance-worker.ts --once",
    "finance:worker": "tsx scripts/finance-worker.ts",
    "onchain:sync-once": "tsx scripts/onchain-worker.ts --once",
    "onchain:worker": "tsx scripts/onchain-worker.ts",
    "env:check:prod": "NODE_ENV=production node --import tsx scripts/check-production-env.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "next": "16.2.3",
    "pg": "8.20.0",
    "prisma": "7.7.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "^20.19.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "^17.2.3",
    "eslint": "^9.38.0",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "4.2.2",
    "tsx": "^4.20.6",
    "typescript": "5.9.3"
  }
}
